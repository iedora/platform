{
  "name": "@iedora/service-billing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Billing service (Hono/Bun): subscriptions + the append-only invoice ledger over a code-defined plan registry, Stripe/manual payment kinds, and marketplace payouts/refunds. Standalone, framework-direct (@iedora/service-kit); owns its money math (src/money); audit crosses the wire via @iedora/sdk/audit.",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "migrate": "bun run src/migrate.ts",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "dependencies": {
    "@hono/zod-validator": "catalog:",
    "@iedora/sdk": "workspace:*",
    "@iedora/auth-sdk": "workspace:*",
    "@iedora/db": "workspace:*",
    "@iedora/messaging": "workspace:*",
    "@iedora/service-kit": "workspace:*",
    "hono": "catalog:",
    "kysely": "catalog:",
    "pg": "catalog:",
    "stripe": "^22.3.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "^8.11.10",
    "jose": "catalog:",
    "typescript": "catalog:",
    "@iedora/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
