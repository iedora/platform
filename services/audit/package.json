{
  "name": "@iedora/service-audit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Audit service (Hono/Bun): ingests audit events from every producer over HTTP and serves the read/query API over the append-only audit_log. Standalone, framework-direct (@iedora/service-kit + @iedora/audit).",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "migrate": "bun run src/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.9.0",
    "@iedora/db": "workspace:*",
    "@iedora/messaging": "workspace:*",
    "@iedora/service-kit": "workspace:*",
    "hono": "^4.12.30",
    "kysely": "^0.29.3",
    "pg": "^8.13.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^22",
    "@types/pg": "^8.11.10",
    "jose": "^5.9.6",
    "typescript": "^5.9.3"
  }
}
