{
  "name": "@iedora/service-classroom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted 1:1 video classroom (Hono/Node): verifies a signed room token, serves the room page, and relays WebRTC signaling over WebSocket. Replaces the external LessonSpace dependency.",
  "scripts": {
    "dev": "node --watch src/index.ts",
    "start": "node src/index.ts",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "dependencies": {
    "@hono/node-ws": "catalog:",
    "@iedora/common": "workspace:*",
    "@iedora/service-kit": "workspace:*",
    "hono": "catalog:",
    "jose": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/ws": "^8.5.13",
    "typescript": "catalog:",
    "@iedora/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
