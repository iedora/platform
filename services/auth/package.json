{
  "name": "@iedora/service-auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multi-tenant authentication service. Provider-agnostic (email/password + any OAuth2/OIDC), issues Ed25519 JWTs with JWKS + OIDC discovery. Shared across iedora services and usable by any external domain.",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "migrate": "bun src/platform/migrate.ts",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "dependencies": {
    "@hono/zod-validator": "catalog:",
    "@iedora/sdk": "workspace:*",
    "@iedora/db": "workspace:*",
    "@iedora/messaging": "workspace:*",
    "@iedora/server-kit": "workspace:*",
    "hono": "catalog:",
    "jose": "catalog:",
    "kysely": "catalog:",
    "pg": "catalog:",
    "zod": "catalog:",
    "@hono/node-server": "catalog:",
    "@node-rs/argon2": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/pg": "^8.11.10",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@iedora/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
