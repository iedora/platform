# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/iedora_auth

# Public issuer URL (goes into JWT `iss` + OIDC discovery). No trailing slash.
ISSUER_URL=http://localhost:4000

# Ed25519 signing key seed (base64url of 32 bytes). Generate once:
#   bun -e "console.log(Buffer.from(crypto.getRandomValues(new Uint8Array(32))).toString('base64url'))"
# Rotate by adding a new seed as the first entry (comma-separated); older keys
# stay published in JWKS so in-flight tokens still verify.
JWT_SIGNING_KEYS=

# Access-token lifetime (seconds) and refresh-token lifetime (seconds).
ACCESS_TTL=900
REFRESH_TTL=2592000

PORT=4000
