#!/usr/bin/env bash
# Pre-commit hook — local mirror of the CI policy gates.
#   Gate: actionlint on CI workflow files.
# Installed by `bun install` (via root postinstall script).
set -euo pipefail

[ -n "${CI:-}" ] && exit 0

changed=$(git diff --cached --name-only --diff-filter=ACM)

# ── Gate: actionlint on CI files ──
ci_changed=$(echo "$changed" | grep -E '^\.github/(workflows|actions)/' || true)
if [ -z "$ci_changed" ]; then
  exit 0
fi

# Ensure actionlint is on PATH (download if missing, like CI).
if ! command -v actionlint &>/dev/null; then
  if [ -f ./actionlint ]; then
    PATH="$PWD:$PATH"
  else
    echo "pre-commit: downloading actionlint..."
    bash <(curl -fsSL https://raw.githubusercontent.com/rhysd/actionlint/main/scripts/download-actionlint.bash) >/dev/null 2>&1
    PATH="$PWD:$PATH"
  fi
fi

echo "pre-commit: linting CI files..."
echo "$ci_changed" | while read -r f; do echo "  $f"; done

# actionlint auto-detects the project root via .github/workflows/.
echo ""
if ! actionlint -color .github/workflows/*.yml; then
  echo ""
  echo "pre-commit: actionlint failed. Fix the issues above and try again."
  exit 1
fi

echo ""
echo "pre-commit: OK"
