{
  "name": "@iedora/service-tutor",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts"
  },
  "imports": {
    "#db": "./src/db/index.ts",
    "#db/*": "./src/db/*.ts",
    "#contracts/*": "./src/contracts/*.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@iedora/service-kit": "workspace:*",
    "@iedora/auth-sdk": "workspace:*",
    "@iedora/sdk": "workspace:*",
    "@iedora/db": "workspace:*",
    "hono": "^4.12.30",
    "inngest": "^4.12.1",
    "kysely": "^0.29.3",
    "luxon": "^3.7.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/luxon": "^3.7.2",
    "@types/node": "^22.20.1",
    "typescript": "5.9.3"
  }
}
