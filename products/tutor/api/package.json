{
  "name": "@iedora/service-tutor",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts"
  },
  "imports": {
    "#db": "./src/db/index.ts",
    "#db/*": "./src/db/*.ts",
    "#contracts/*": "./src/contracts/*.ts"
  },
  "scripts": {
    "dev": "node --watch src/index.ts",
    "start": "node src/index.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "dependencies": {
    "@iedora/service-kit": "workspace:*",
    "@iedora/auth-sdk": "workspace:*",
    "@iedora/sdk": "workspace:*",
    "@iedora/db": "workspace:*",
    "@iedora/jobs": "workspace:*",
    "@iedora/common": "workspace:*",
    "hono": "catalog:",
    "jose": "catalog:",
    "kysely": "catalog:",
    "luxon": "^3.7.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/luxon": "^3.7.2",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@iedora/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
