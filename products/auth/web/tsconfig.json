{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "es2023"],
    "allowJs": true,
    "jsx": "preserve",
    // Composite project — apps/web references this via `tsc --build`; emits only
    // .d.ts to ./dist, runtime keeps reading the .ts sources via transpilePackages.
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", ".next", "dist", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
