# Local dev env. Real values for everything the menu app reads at
# runtime. The dev orchestrator (`go run ./dev/cmd/local-stack`) rewrites
# this file when the local Postgres + better-auth bootstrap finishes.
# Overrides live in `.env.local` (gitignored, user-owned).

DATABASE_URL=postgresql://postgres:Password1!@localhost:5432/menu
CORE_DATABASE_URL=postgresql://postgres:Password1!@localhost:5432/core
IEDORA_CORE_SECRET=dev-iedora-auth-secret-do-not-use-in-prod-32chars
IEDORA_CORE_BASE_URL=http://localhost:3000
IEDORA_CORE_TRUSTED_ORIGINS=http://localhost:3000
IEDORA_CORE_COOKIE_DOMAIN=localhost
NEXT_PUBLIC_CORE_URL=http://localhost:3000/core
GIT_SHA=
HOST_NAME=
MENU_PUBLIC_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1
NODE_ENV=development
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:5080/api/default
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20ZGV2QGllZG9yYS5sb2NhbDpQYXNzd29yZDEh
S3_ACCESS_KEY=test
S3_BUCKET=iedora-assets
S3_ENDPOINT=http://localhost:4566
S3_PUBLIC_URL=http://localhost:4566/iedora-assets
S3_REGION=us-east-1
S3_SECRET_KEY=test
