# Test fixtures. Single source for the env every E2E surface needs —
# Playwright workers, the production-build Next.js webServer, the
# Zitadel mock, and every CI step. Same shape as the dev `.env` (TF-
# emitted) so the schema stays homogeneous; values are test fakes.
#
# Load contract:
#   - Locally: `bun --env-file=.env.test ...` (baked into the
#     test:e2e + test:e2e:* scripts in package.json).
#   - In CI: the menu workflow runs the same scripts; --env-file
#     pulls this file from the workspace.
#
# To override a value locally (e.g. point at MinIO instead of S3Mock),
# either `S3_ENDPOINT=... bun run test:e2e` or create a sibling
# `.env.test.local` and add a second `--env-file` flag in the script.

NODE_ENV=production
DATABASE_URL=postgresql://postgres:Password1!@localhost:5432/menu_test
MENU_PUBLIC_URL=http://localhost:3000
MENU_SESSION_SECRET=test-secret-do-not-use-in-prod-test-secret-do-not-use-in-prod
DISABLE_RATE_LIMIT=true

# Zitadel mock — `tests/e2e/_bootstrap.ts` listens on this port.
ZITADEL_ISSUER_URL=http://127.0.0.1:4444
ZITADEL_OAUTH_CLIENT_ID=menu
ZITADEL_OAUTH_CLIENT_SECRET=menu-secret
ZITADEL_MANAGEMENT_TOKEN=test-pat
ZITADEL_ACTION_SIGNING_KEY=test-signing-key
ZITADEL_GRANTS_SIGNING_KEY=test-grants-signing-key

# S3 mock — adobe/s3mock in CI (also fine locally via
# `docker run -d -p 9090:9090 -e initialBuckets=menu-test adobe/s3mock:latest`).
# Devs running the LocalStack stack should override S3_ENDPOINT to
# http://localhost:4566 via shell or .env.test.local.
S3_ENDPOINT=http://localhost:9090
S3_REGION=us-east-1
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=menu-test
