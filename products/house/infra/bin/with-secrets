#!/bin/sh
# Wrap a command with secrets fetched from Bitwarden Secrets Manager,
# then exec the command in-place. The wrapped process inherits all BWS
# secrets as env vars + the TF_VAR_* aliases the house Tofu root expects.
#
# House needs less than menu — just account_id + cloudflare_api_token +
# state_passphrase. zone_name defaults to "iedora.com" in variables.tf.
#
# Operator only has to provide ONE thing — `BWS_ACCESS_TOKEN` — in their
# shell (e.g. `source ~/.secrets`). Everything else self-discovers:
#   BWS_PROJECT_ID         picked from `bws project list` (iedora-deploy).
#   CLOUDFLARE_ACCOUNT_ID  resolved from CF's /accounts API using
#                          INFRA_CLOUDFLARE_API_TOKEN once BWS is loaded.
#
# Why we DON'T use `bws run`: it spawns a child process that resets cwd
# and swallows the first line of stdout. We just `bws secret list -o env`
# + eval into the current shell, then exec — no subprocess oddities.
#
# Usage:
#   infra/bin/with-secrets <cmd> [args...]

set -eu

: "${BWS_ACCESS_TOKEN:?BWS_ACCESS_TOKEN missing — export it in your shell (e.g. source ~/.secrets)}"

if [ -z "${BWS_PROJECT_ID:-}" ]; then
  BWS_PROJECT_ID=$(bws project list -o json \
    | python3 -c "import json,sys; ps=[p['id'] for p in json.load(sys.stdin) if p['name']=='iedora-deploy']; print(ps[0] if ps else '', end='')")
  : "${BWS_PROJECT_ID:?bws project list returned no iedora-deploy project — check BWS_ACCESS_TOKEN scope}"
  export BWS_PROJECT_ID
fi

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)

# Load every BWS secret as an env var. Same workaround the infra wrapper
# uses: bash 3.2 (still the macOS default) mangles eval of multi-line
# single-quoted strings — INFRA_SSH_PRIVATE_KEY's PEM newlines get
# resolved mid-eval and trip "RSA: command not found". Materialize the
# env via python's shlex.quote (POSIX-safe single-quoting), source the
# tempfile. Plays nice with bash 3.2 + dash + zsh.
TMPENV=$(mktemp -t bws-env.XXXXXX)
trap 'rm -f "$TMPENV"' EXIT
bws secret list "$BWS_PROJECT_ID" -o json \
  | python3 "$SCRIPT_DIR/_bws-to-env.py" > "$TMPENV" \
  || { echo "with-secrets: BWS fetch/parse failed" >&2; exit 1; }
# shellcheck disable=SC1090
. "$TMPENV"

if [ -z "${CLOUDFLARE_ACCOUNT_ID:-}" ]; then
  : "${INFRA_CLOUDFLARE_API_TOKEN:?INFRA_CLOUDFLARE_API_TOKEN missing in BWS}"
  CLOUDFLARE_ACCOUNT_ID=$(curl -fsS -H "Authorization: Bearer $INFRA_CLOUDFLARE_API_TOKEN" \
    "https://api.cloudflare.com/client/v4/accounts" \
    | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['result'][0]['id'], end='')")
  : "${CLOUDFLARE_ACCOUNT_ID:?CF /accounts returned no account — check INFRA_CLOUDFLARE_API_TOKEN}"
  export CLOUDFLARE_ACCOUNT_ID
fi

# TF_VAR_* aliases — Tofu reads inputs from these specific names.
export TF_VAR_account_id="$CLOUDFLARE_ACCOUNT_ID"
export TF_VAR_cloudflare_api_token="${INFRA_CLOUDFLARE_API_TOKEN:?INFRA_CLOUDFLARE_API_TOKEN missing in BWS}"
export TF_VAR_state_passphrase="${INFRA_STATE_PASSPHRASE:?INFRA_STATE_PASSPHRASE missing in BWS}"

exec "$@"
