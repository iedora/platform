#!/usr/bin/env bash
# Transparent wrapper for zitadel-apply at app-state/zitadel.
# `go run` compiles once into GOCACHE; subsequent invocations reuse the
# cached binary.
#
# Stage 3 configurator. Reconciles the Zitadel IdP (org, project, OIDC app, machine user + PAT, action targets, admin grants). --grants-only for the legacy zitadel-grant behavior.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$DIR")"

exec go run -C "$REPO_ROOT" ./app-state/zitadel "$@"
