#!/usr/bin/env bash
# Transparent wrapper for menu-db-migrations at app-state/menu-db-migrations.
# `go run` compiles once into GOCACHE; subsequent invocations reuse the
# cached binary.
#
# Stage 3 configurator. Runs drizzle-kit migrate against the live menu DB via SSH + 'docker run --rm' against the current menu image.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$DIR")"

exec go run -C "$REPO_ROOT" ./app-state/menu-db-migrations "$@"
