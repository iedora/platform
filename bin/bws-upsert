#!/usr/bin/env bash
# Transparent wrapper for bws-upsert at infra/bws-upsert.
# `go run` compiles once into GOCACHE; subsequent invocations reuse the
# cached binary.
#
# Stage 2 helper. Invoked by terraform_data.bws_sync_autogen in infra/tofu/secrets.tf to write AUTOGEN values back to BWS. Reads BWS_PROJECT_ID, BWS_KEY, BWS_VALUE from env.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$DIR")"

exec go run -C "$REPO_ROOT" ./infra/bws-upsert "$@"
