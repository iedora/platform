#!/usr/bin/env bash
# Transparent wrapper for the iedora orchestrator at deploy/iedora.
# `go run` compiles once into GOCACHE; subsequent invocations reuse the
# cached binary.
#
# This wrapper does NOT layer bin/with-secrets automatically. The
# Taskfile (or a CI workflow, or the operator) chooses the right
# `--stage` for the subcommand being invoked:
#
#   task infra:up    → with-secrets --stage iac    -- bin/iedora iac apply
#   task app:apply   → with-secrets --stage app    -- bin/iedora app apply
#   task deploy:menu → with-secrets --stage deploy --product menu -- bin/iedora deploy menu
#
# `bin/iedora doctor` and `bin/iedora --help` run fine without
# with-secrets — they only need BWS_ACCESS_TOKEN which the operator's
# shell already exports.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$DIR")"

exec go run -C "$REPO_ROOT" ./deploy/iedora "$@"
