#!/usr/bin/env bash
# Transparent wrapper for with-secrets at deploy/with-secrets.
# `go run` compiles once into GOCACHE; subsequent invocations reuse the
# cached binary.
#
# Hydrates the spawned process's env from BWS, filtered to the active --stage. CWD trap: forwards ORIG_PWD so 'tofu -chdir=tofu' resolves against the operator's cwd, not the module root.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$DIR")"

exec go run -C "$REPO_ROOT" ./deploy/with-secrets "$@"
