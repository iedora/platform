#!/usr/bin/env bash
# Transparent wrapper for openobserve-dashboards at app-state/openobserve-dashboards.
# `go run` compiles once into GOCACHE; subsequent invocations reuse the
# cached binary.
#
# Stage 3 configurator. Opens an SSH local-forward tunnel to the Hetzner box and pushes the embedded dashboard JSONs (go:embed) to the OpenObserve API.
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$DIR")"

exec go run -C "$REPO_ROOT" ./app-state/openobserve-dashboards "$@"
