# Copy to infra/.env (gitignored) and fill in the REQUIRED values.
# Blank values under "Auto-generated" will be filled in on first `make deploy`
# and saved back to this file — keep that file in your password manager too.

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Cloudflare — dashboard right sidebar (account + zone) and Profile → API Tokens.
# Token scopes: Account · Cloudflare Tunnel · Edit, Zone · DNS · Edit (scoped),
# Account · Account Settings · Read.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Public hostname for the app (must be a subdomain of your Cloudflare zone).
# Assets are served from `assets.<rest-of-hostname>` automatically.
PUBLIC_HOSTNAME=menu.example.com

# Homelab box — IP or hostname, plus the existing sudo user (the one you
# created when installing Ubuntu). Used only for `host-init` on first run.
ONPREM_HOST=192.168.50.53
BOOTSTRAP_USER=pwu

# ── AUTO-GENERATED on first run (leave blank) ────────────────────────────────
# Filled in by `infra/deploy.sh` and saved back to this file. ≥ 16 chars each.

STATE_PASSPHRASE=
BETTER_AUTH_SECRET=
POSTGRES_PASSWORD=
MINIO_ROOT_PASSWORD=
REGISTRY_PASSWORD=

# ── STATIC DEFAULTS (leave as-is unless you know why) ────────────────────────

MINIO_ROOT_USER=metamenu
