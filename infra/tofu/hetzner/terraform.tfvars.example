# Copy to `terraform.tfvars` (gitignored) — or, preferred, set everything as
# TF_VAR_* env vars (direnv / 1Password CLI). Secrets in env vars never
# touch disk except inside the OpenTofu state, which is encrypted (see
# versions.tf).

server_type = "cx22"   # 2 vCPU, 4 GB RAM
location    = "nbg1"   # nbg1 | fsn1 | hel1 | ash | hil | sin

# Secrets — strongly prefer TF_VAR_* env vars over committing to a file.
# hcloud_token     = "..."   # https://console.hetzner.cloud → project → API Tokens
# state_passphrase = "..."   # ≥ 16 chars. Store in your password manager.
