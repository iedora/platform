# Secrets partilhados entre destinations. Template — sem secrets em
# plain text (fetch via adapter bitwarden-sm em runtime), por isso
# tracked. Pré-requisito: BWS_ACCESS_TOKEN exportado na shell.

SECRETS=$(kamal secrets fetch --adapter bitwarden-sm all)

# Gitea OCI registry token — para push/pull de git.iedora.com/eduvhc/web.
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract GITEA_REGISTRY_TOKEN $SECRETS)
