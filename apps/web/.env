# Single source of truth for LOCAL DEV env (runtime).
# Consumed by next dev (`bun run dev`). The backend (Postgres, MinIO,
# NATS, the Go services) lives in services/docker-compose.yml —
# `bun run dev:up`. Tracked — sem secrets, só valores fake locais.

# --- Hono backend (services/, iedora-api-* host ports) ---
AUTH_URL=http://localhost:8180
MENU_URL=http://localhost:8184

# --- Public surface URLs (plain runtime env; set per environment) ---
MENU_SURFACE_URL=http://localhost:3000/menu
BRAND_URL=http://localhost:3000/house
