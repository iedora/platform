# Single source of truth for LOCAL DEV env (runtime).
# Consumed by next dev (`bun run dev`). The backend (Postgres, MinIO,
# NATS, the services) lives in services/docker-compose.yml —
# `bun run api:up`. Tracked — sem secrets, só valores fake locais.

# --- Hono backend (services/, iedora-api-* host ports) ---
AUTH_URL=http://localhost:8180
MENU_URL=http://localhost:8184

# --- Public surface URLs (plain runtime env; set per environment) ---
MENU_SURFACE_URL=http://localhost:3000/menu
HOUSE_SURFACE_URL=http://localhost:3000/house
BRAND_URL=http://localhost:3000/house

# --- OpenTelemetry (local) → the infra/local LGTM stack's collector ---
# next dev runs on the host, so localhost:4318 reaches the collector's published
# port. Bring the stack up (docker compose -f ../infra/local/compose.yaml up -d)
# then open Grafana at http://localhost:3001. With it down, exports fail (non-
# fatal). Cumulative temporality is mandatory for the Prometheus backend.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=cumulative
