.git
.github
.next
node_modules
.DS_Store
*.log

# Every env variant — keep the broad glob so `.env`, `.env.production`,
# `.env.preview`, etc. never leak into the image. `infra/.env.example`
# is already covered by the `infra/` rule below. The `**/` prefix is
# load-bearing: without it the pattern only matched root-level `.env*`.
#
# Builds run from the Mac (infra/live/deploy.sh) — apps/web/.env exists
# locally with dev URLs (NEXT_PUBLIC_*=http://localhost:3000/...). It
# MUST NOT enter the build context: Next.js would inline those localhost
# values into the client bundle. With .env excluded, productUrl()'s `??`
# fallback returns the canonical `https://<id>.iedora.com` URL.
**/.env*


docs/
tests/
playwright-report/
test-results/

# Test sources scattered under src/. Standalone output tracing already
# strips them at build time, but excluding them keeps the build context
# smaller and the COPY faster.
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# IDE / Claude
.vscode/
.idea/
.claude/

# TypeScript incremental build output
**/*.tsbuildinfo
**/tsconfig.tests.json

# Test coverage
coverage/

# Database backups — never allowed in image context. Even gpg-encrypted
# dumps leak volume + schedule metadata from the filenames.
*.dump
*.dump.gpg
*.sql.gz
*.bak

# Stray compiled binaries at the repo root: they inflate the build context
# but are never used by the image.
/bws-sync
/bws-upsert
/iedora
/menu-db-migrations
/openobserve-dashboards
/state-bucket-bootstrap

# Playwright — browser binaries + merge artefacts + auth state
playwright/.cache/
blob-report/
playwright/.auth/
.playwright-mcp/

# Vitest runner cache
.vitest-cache/

# Local reference checkouts
services-references/

# Build output
dist/
