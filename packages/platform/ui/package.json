{
  "name": "@iedora/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "iedora UI — shadcn/ui on Base UI primitives.",
  "sideEffects": [
    "./src/styles.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./lib/utils": "./src/lib/utils.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "eslint src --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "next-themes": "^0.4.6",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
