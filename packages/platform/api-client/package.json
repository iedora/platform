{
  "name": "@iedora/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Server-only HTTP client for the Hono backend (BFF-lite): auth cookie handling, access-token session decode, and a Bearer-attaching fetch with one-shot refresh. Edge-compatible — importable from Next middleware, RSCs, server actions, and route handlers. The browser never calls the services directly.",
  "exports": {
    ".": "./src/index.ts",
    "./middleware": "./src/middleware.ts",
    "./menu-rpc": "./src/menu-rpc.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "eslint src --cache --cache-location node_modules/.cache/.eslintcache",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@iedora/auth-sdk": "^0.1.1",
    "@iedora/contracts": "workspace:*",
    "@iedora/service-menu": "workspace:*",
    "hono": "catalog:",
    "openapi-fetch": "^0.17.0"
  },
  "peerDependencies": {
    "next": "^16.2.6"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "@types/node": "^22.19.19",
    "eslint": "catalog:",
    "next": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
