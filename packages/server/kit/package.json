{
  "name": "@iedora/server-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared backend runtime for the iedora Hono services (Bun): env loading with the _FILE secret convention, graceful Bun.serve bootstrap, and the Kysely connection + transaction-in-context plumbing.",
  "exports": {
    ".": "./src/index.ts",
    "./env": "./src/env.ts",
    "./boot": "./src/boot.ts",
    "./db": "./src/db.ts",
    "./http": "./src/http.ts",
    "./jwt": "./src/jwt.ts",
    "./audit": "./src/audit.ts",
    "./outbox": "./src/outbox.ts",
    "./password": "./src/password.ts",
    "./tokens": "./src/tokens.ts",
    "./migrate": "./src/migrate.ts",
    "./serviceauth": "./src/serviceauth.ts",
    "./userauth": "./src/userauth.ts",
    "./testkit": "./src/testkit.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "eslint src --cache --cache-location node_modules/.cache/.eslintcache",
    "test": "bun test"
  },
  "dependencies": {
    "@node-rs/argon2": "catalog:",
    "hono": "catalog:",
    "jose": "catalog:",
    "kysely": "catalog:",
    "kysely-postgres-js": "catalog:"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "@types/bun": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
