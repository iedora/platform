{
  "name": "@iedora/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared zod schemas + inferred types for iedora backend payloads — the single source of truth consumed by both the Hono services (request/response validation) and the Next.js frontend (typed client).",
  "exports": {
    ".": "./src/index.ts",
    "./audit": "./src/audit.ts",
    "./auth": "./src/auth.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "eslint src --cache --cache-location node_modules/.cache/.eslintcache",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "openapi-typescript": "^7.13.0",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
