{
  "name": "@iedora/db",
  "version": "0.8.0",
  "description": "Bun-native Kysely-over-Postgres kit: createDb + a tx-in-context Database class on Bun's SQL driver via kysely-postgres-js, a static-import migration runner (runMigrations), and shared column types.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iedora/framework.git",
    "directory": "packages/db"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "dependencies": {
    "kysely-postgres-js": "catalog:"
  },
  "peerDependencies": {
    "kysely": ">=0.27",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "kysely": "catalog:",
    "postgres": "^3.4.5",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "@iedora/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependenciesMeta": {
    "postgres": {
      "optional": true
    }
  }
}
