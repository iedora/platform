{
  "name": "@iedora/config",
  "version": "0.1.0",
  "description": "Zero-dependency typed environment config for any service: required/optional readers, the _FILE secret convention (Docker/Kamal mounted secrets), duration/number/bool parsing, and an env predicate.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iedora/framework.git",
    "directory": "packages/config"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "@iedora/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
