{
  "name": "@iedora/observability",
  "version": "0.2.0",
  "description": "Idiomatic OpenTelemetry for any Bun/Node service: one register() on the standard NodeSDK (traces + metrics + logs over OTLP proto), a generic baggage-driven span-attribution processor (no domain keys), and tracer/meter/logger accessors that are safe to call before registration.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iedora/framework.git",
    "directory": "packages/observability"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "dependencies": {
    "@opentelemetry/baggage-span-processor": "catalog:",
    "@opentelemetry/exporter-logs-otlp-proto": "catalog:",
    "@opentelemetry/exporter-metrics-otlp-proto": "catalog:",
    "@opentelemetry/exporter-trace-otlp-proto": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-logs": "catalog:",
    "@opentelemetry/sdk-metrics": "catalog:",
    "@opentelemetry/sdk-node": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.220.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/api-logs": "catalog:",
    "@opentelemetry/context-async-hooks": "catalog:",
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "@iedora/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
