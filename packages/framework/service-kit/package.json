{
  "name": "@iedora/service-kit",
  "version": "0.4.1",
  "description": "The shared Bun+Hono runtime every iedora backend service reuses: createServiceApp (Hono + OTel + onError), graceful Bun.serve, the Kysely tx-in-context Database, runMigrations, healthRoutes, span attribution, and _FILE env secrets. Re-exports @iedora/server-kit.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./testkit": "./src/testkit.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iedora/framework.git",
    "directory": "packages/service-kit"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "dependencies": {
    "@iedora/config": "workspace:*",
    "@iedora/db": "workspace:*",
    "@iedora/observability": "workspace:*",
    "@iedora/server-kit": "workspace:*",
    "@hono/otel": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:"
  },
  "peerDependencies": {
    "hono": ">=4",
    "kysely": ">=0.27"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "hono": "catalog:",
    "kysely": "catalog:",
    "typescript": "catalog:",
    "@iedora/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
