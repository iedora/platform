{
  "name": "@iedora/messaging",
  "version": "0.2.1",
  "description": "Generic transactional outbox + idempotent inbox for Postgres/Kysely: at-least-once delivery via SELECT ... FOR UPDATE SKIP LOCKED, retries with jittered exponential backoff, and dead-lettering. So services don't reimplement reliable messaging.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iedora/framework.git",
    "directory": "packages/messaging"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache"
  },
  "peerDependencies": {
    "kysely": ">=0.27"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "kysely": "catalog:",
    "kysely-postgres-js": "catalog:",
    "typescript": "catalog:",
    "@iedora/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:",
    "postgres": "^3.4.5"
  }
}
