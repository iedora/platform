{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig*.json"],
      "outputs": []
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "eslint.config.mjs"],
      "outputs": []
    },
    "test": {
      "outputs": ["coverage/**"],
      "passThroughEnv": [
        "TEST_DATABASE_URL",
        "DATABASE_URL",
        "S3_TEST_ENDPOINT",
        "S3_TEST_ACCESS_KEY",
        "S3_TEST_SECRET_KEY",
        "S3_TEST_BUCKET",
        "S3_TEST_REGION"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**"]
    }
  }
}
