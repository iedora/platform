{
  "name": "iedora",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/platform/*",
    "packages/server/*",
    "products/*",
    "services/*",
    "apps/*",
    "integration"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "api:up": "docker compose up -d --build",
    "api:down": "docker compose down",
    "api:logs": "docker compose logs -f",
    "api:reset": "docker compose down -v",
    "typecheck": "bun run scripts/run-parallel.mjs typecheck",
    "lint": "bun run scripts/run-parallel.mjs lint",
    "test": "bun run --workspaces test",
    "postinstall": "[ -n \"${CI:-}\" ] && exit 0; mkdir -p .git/hooks && cp scripts/git-hooks/pre-commit .git/hooks/pre-commit && cp scripts/git-hooks/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/pre-commit .git/hooks/commit-msg && echo '✓ git hooks installed (pre-commit: actionlint on .github/workflows/, commit-msg: conventional)' || true"
  },
  "catalog": {
    "zod": "^4.4.3",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "5.0.0-beta.3",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^22.19.19",
    "@types/bun": "^1.3.14",
    "hono": "^4.12.25",
    "@hono/otel": "^1.1.2",
    "@hono/zod-validator": "^0.8.0",
    "kysely-codegen": "^0.20.0",
    "pg": "^8.21.0",
    "kysely": "^0.29.2",
    "kysely-postgres-js": "^3.0.0",
    "jose": "^6.2.3",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "testcontainers": "^12.0.3",
    "@testcontainers/postgresql": "^12.0.3"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "shadcn": "^4.11.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "postcss": "^8.5.14"
  }
}
