{
  "name": "iedora",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "products/*/*",
    "services/*",
    "packages/framework/*",
    "packages/sdk/*",
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "api:up": "docker compose up -d --build",
    "api:down": "docker compose down",
    "api:logs": "docker compose logs -f",
    "api:reset": "docker compose down -v",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint && turbo run lint",
    "test": "turbo run test",
    "postinstall": "[ -n \"${CI:-}\" ] && exit 0; mkdir -p .git/hooks && cp scripts/git-hooks/pre-commit .git/hooks/pre-commit && cp scripts/git-hooks/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/pre-commit .git/hooks/commit-msg && echo '✓ git hooks installed (pre-commit: actionlint on .github/workflows/, commit-msg: conventional)' || true",
    "oxlint": "oxlint",
    "typecheck:parallel": "bun run scripts/run-parallel.mjs typecheck"
  },
  "catalog": {
    "zod": "^4.4.3",
    "eslint": "^9.39.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "5.0.0-beta.6",
    "next": "16.2.11",
    "next-intl": "^4.13.3",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^24.13.3",
    "@types/bun": "^1.3.14",
    "hono": "^4.12.31",
    "@hono/otel": "^1.1.2",
    "@hono/zod-validator": "^0.9.0",
    "kysely-codegen": "^0.20.0",
    "pg": "^8.22.0",
    "kysely": "^0.29.4",
    "kysely-postgres-js": "^3.0.0",
    "jose": "^6.2.3",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "jsdom": "^29.1.1",
    "eslint-plugin-oxlint": "^1.73.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "oxlint": "^1.74.0",
    "shadcn": "^4.11.0",
    "turbo": "^2.10.5"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "postcss": "^8.5.14",
    "js-yaml": "^4.3.0",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "dependencies": {
    "@iedora/db": "workspace:*",
    "@iedora/service-kit": "workspace:*",
    "next": "^16.2.10"
  },
  "packageManager": "bun@1.3.14"
}
