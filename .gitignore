# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/
/playwright/.auth/

# Claude Code — local user settings (skills are shared)
.claude/settings.local.json
.claude/

# Infra — artefactos locais não versionados
infra/**/*.iso
infra/tofu/**/.terraform/
infra/tofu/**/.terraform.lock.hcl
infra/tofu/**/terraform.tfstate
infra/tofu/**/terraform.tfstate.backup
infra/tofu/**/terraform.tfvars
!infra/tofu/**/terraform.tfvars.example
