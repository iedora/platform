# See https://git-scm.com/docs/gitignore for more about ignoring files.

# dependencies — bun workspaces resolve from the repo root, so the only
# node_modules anywhere should be at the root (plus a symlink-style
# layout in each workspace).
node_modules/

# testing
/coverage
.vitest-cache/

# next.js
.next/
/out/

# production
/build

# Playwright
test-results/
playwright-report/
playwright/.cache/
blob-report/
playwright/.auth/

# Local reference checkouts (not part of the repo)
.playwright-mcp/
services-references/
service-references/

# Ad-hoc screenshots from Playwright / dev sessions land in the repo
# root. Intentional fixture screenshots live under tests/e2e/screenshots/.
/*.png

# Backup artefacts — `bin/iedora backup` and ad-hoc pg_dump leave these
# in cwd. Database dumps are the most sensitive payload anywhere in the
# repo; never commit one even gpg-encrypted (the shape leaks volume +
# schedule).
*.dump
*.dump.gpg
*.sql.gz
*.bak

# Operator env (home-infra/.env) é coberto pela rule `.env` global mais
# abaixo. Shape em home-infra/.env.example.

# Stray compiled binaries at the repo root — never committed.
/bws-sync
/bws-upsert
/iedora
/menu-db-migrations
/openobserve-dashboards
/state-bucket-bootstrap

# OS / editor
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*

# env files. App envs vivem em `apps/web/` (tracked: `.env` + `.env.test`,
# negados abaixo). `.env.local` fica untracked — Next.js layera por cima
# e faz hot-reload quando muda; usa para secrets (AI keys, real S3 creds).
.env
.env.local
.env.production
.env.*.local

# Apps/web tracked envs — dev defaults + E2E test build. Prod secrets live in
# the infra repo (iedora/infra/stacks/web/secrets.env), not here.
!apps/web/.env
!apps/web/.env.test

# sops edit/set leftover (decrypted plaintext) — never commit
.decrypted~*

# home-infra/<service>/.env é COMMITTED — só config non-secret (ex:
# email, domain). Secrets ficam em BWS, injectados em runtime via
# `bws run`. Negate a rule `.env` global acima para estes paths:
!home-infra/*/.env
!home-infra/my-services/*/.env
!home-infra/my-services/*/*/.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts



# Claude Code — local user settings, scheduled-task locks, etc. Skills
# under `.claude/skills/` are shared and stay tracked.
.claude/*
!.claude/skills/

# Playwright testkit handoff
products/menu/tests/e2e/.testkit.json
dist/


menu-taberna-do-jose.extracted.json

# Local-dev fingerprint cache for `bun run dev` migrate skip.
.dev-cache/

# Tooling binaries downloaded by pre-commit hooks (platform-specific).
/actionlint

# Turborepo local cache
.turbo/
