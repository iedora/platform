    "t-feat-photo-b": {
      "type": "string",
      "value": [
        {
          "value": "Show every dish with mouth-watering photos, clear descriptions, allergens, and prices.",
          "theme": {
            "lang": "en"
          }
        },
        {
          "value": "Mostre cada prato com fotos irresistíveis, descrições claras, alérgenos e preços.",
