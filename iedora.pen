    "t-feat-lang-b": {
      "type": "string",
      "value": [
        {
          "value": "Serve every guest in their language with automatic, fully editable menu translations.",
          "theme": {
            "lang": "en"
          }
        },
        {
          "value": "Atenda cada cliente no idioma dele com traduções automáticas e totalmente editáveis.",
          "theme": {
            "lang": "pt"
          }
        }
      ]
    },
    "t-feat-lang-t": {
      "type": "string",
      "value": [
        {
          "value": "Instant translations",
          "theme": {
            "lang": "en"
          }
        },
        {
          "value": "Traduções instantâneas",
          "theme": {
            "lang": "pt"
          }
        }
      ]
    },
    "t-feat-order-b": {
      "type": "string",
      "value": [
        {
          "value": "Let guests order and pay from the table, with tickets sent straight to your kitchen.",
          "theme": {
            "lang": "en"
