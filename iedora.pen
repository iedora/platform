    "t-feat-edit-b": {
      "type": "string",
      "value": [
        {
          "value": "Change a price, mark a dish sold out, or launch a daily special from your phone — live immediately.",
          "theme": {
            "lang": "en"
          }
        },
        {
          "value": "Mude um preço, marque um prato esgotado ou lance o prato do dia pelo celular — no ar na hora.",
          "theme": {
            "lang": "pt"
          }
        }
      ]
    },
    "t-feat-edit-t": {
      "type": "string",
      "value": [
        {
