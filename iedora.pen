            "lang": "pt"
          }
        }
      ]
    },
    "t-feat-photo-t": {
      "type": "string",
      "value": [
        {
          "value": "Photo-rich items",
          "theme": {
            "lang": "en"
          }
        },
        {
          "value": "Itens com fotos",
          "theme": {
            "lang": "pt"
