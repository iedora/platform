    "t-feat-scan-b": {
      "type": "string",
      "value": [
        {
          "value": "Guests scan a QR code or tap a link and your menu opens instantly — no app to download, ever.",
          "theme": {
            "lang": "en"
          }
        },
        {
          "value": "Os clientes escaneiam um QR code ou tocam num link e o cardápio abre na hora — sem nunca baixar um app.",
          "theme": {
            "lang": "pt"
          }
        }
      ]
    },
    "t-feat-scan-t": {
      "type": "string",
      "value": [
