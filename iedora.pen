        {
          "value": "Cardápios digitais para restaurantes",
          "theme": {
            "lang": "pt"
          }
        }
      ]
    },
    "t-hero-headline": {
      "type": "string",
      "value": [
        {
          "value": "Your menu, beautifully digital — live in minutes.",
          "theme": {
            "lang": "en"
          }
        },
        {
          "value": "Seu cardápio, lindamente digital — no ar em minutos.",
          "theme": {
            "lang": "pt"
          }
        }
      ]
    },
    "t-hero-subhead": {
      "type": "string",
      "value": [
        {
          "value": "iedora turns your menu into a stunning, always-up-to-date digital experience your guests scan, browse, and order from — no app, no printing, no reprints.",
          "theme": {
            "lang": "en"
          }
        },
        {
          "value": "A iedora transforma seu cardápio numa experiência digital linda e sempre atualizada que seus clientes escaneiam, navegam e pedem — sem app, sem impressão, sem reimpressões.",
          "theme": {
            "lang": "pt"
          }
        }
      ]
    },
    "t-hero-trust": {
      "type": "string",
      "value": [
        {
          "value": "No app to download · Free 14-day trial · Cancel anytime",
          "theme": {
            "lang": "en"
          }
        },
        {
          "value": "Sem app para baixar · 14 dias grátis · Cancele quando quiser",
          "theme": {
            "lang": "pt"
          }
        }
      ]
    },
    "t-how-eyebrow": {
      "type": "string",
      "value": [
        {
          "value": "Up and running today",
          "theme": {
            "lang": "en"
          }
        },
        {
          "value": "No ar hoje mesmo",
          "theme": {
            "lang": "pt"
          }
        }
      ]
    },
    "t-how-s1-b": {
      "type": "string",
      "value": [
        {
          "value": "Add dishes, photos, and prices — or import your existing menu in one click and organize sections in minutes.",
          "theme": {
            "lang": "en"
          }
