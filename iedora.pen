    "t-feat-eyebrow": {
      "type": "string",
      "value": [
        {
          "value": "Everything in one place",
          "theme": {
            "lang": "en"
          }
        },
        {
          "value": "Tudo num só lugar",
          "theme": {
            "lang": "pt"
          }
        }
