    "t-feat-sells-b": {
      "type": "string",
      "value": [
        {
          "value": "See views, taps, and favorites, then feature your best-performing dishes front and center.",
          "theme": {
            "lang": "en"
          }
        },
        {
          "value": "Veja visualizações, toques e favoritos e destaque seus pratos campeões.",
